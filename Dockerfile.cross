FROM docker.io/library/alpine:3.19.0@sha256:51b67269f354137895d43f3b3d810bfacd3945438e94dc5ac55fdac340352f48 AS builder
RUN apk add --no-cache \
    icu-libs \
    sqlite-static \
    yaml-static \
    yaml-dev \
    libxml2-static \
    zlib-static \
    openssl-libs-static \
    openssl-dev \
    musl-dev \
    xz-static \
    gcc \
    pcre2-dev \
    gc-dev \
    libevent-dev

WORKDIR /invidious

ARG INVIDIOUS
COPY ${INVIDIOUS} ./
ARG BUILDLOG
COPY ${BUILDLOG} ./

RUN $(tail -n1 buildlog)