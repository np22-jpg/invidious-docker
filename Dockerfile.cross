FROM docker.io/library/alpine:3.19.1@sha256:c5b1261d6d3e43071626931fc004f70149baeba2c8ec672bd4f27761f8e1ad6b AS builder
RUN apk add --no-cache \
    icu-libs \
    sqlite-static \
    yaml-static \
    yaml-dev \
    libxml2-static \
    zlib-static \
    openssl-libs-static \
    openssl-dev \
    musl-dev \
    xz-static \
    gcc \
    pcre2-dev \
    gc-dev \
    libevent-dev

WORKDIR /invidious

ARG INVIDIOUS
COPY ${INVIDIOUS} ./
ARG BUILDLOG
COPY ${BUILDLOG} ./

RUN $(tail -n1 buildlog)